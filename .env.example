# 微信文章阅读器 - 环境变量配置
#
# 数据库存储方式（二选一）：
#   local    - 使用本地 SQLite，无需外部数据库
#   supabase - 使用 Supabase 云端 PostgreSQL
#   auto     - 自动检测：有 DATABASE_URL 用 supabase，否则用 local
DB_TYPE=auto

# Supabase 数据库连接字符串（DB_TYPE=supabase 时必填）
# 获取方式：Supabase Dashboard -> Connect -> Direct Connection
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Flask 会话密钥（不设置会自动生成并持久化到 .secret_key 文件）
# SECRET_KEY=your_secret_key_here

# 文章缓存有效时间（小时），默认 6 小时
# ARTICLE_CACHE_TTL=6

# 每个公众号最大拉取页数（每页10篇），默认 10 页 = 100 篇
# MAX_ARTICLE_PAGES=10

# 服务端口，默认 5000
# PORT=5000
