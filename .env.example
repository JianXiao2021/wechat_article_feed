# 微信文章阅读器 - 环境变量配置
#
# 数据库存储方式（可选值）：
#   local    - 使用本地 SQLite，无需外部数据库
#   supabase - 使用 Supabase 云端 PostgreSQL
#   auto     - 自动检测：有 DATABASE_URL 用 supabase，否则用 local（默认）
DB_TYPE=auto

# Supabase 数据库连接字符串（DB_TYPE=supabase 时必填）
# 获取方式：Supabase Dashboard -> Project Settings -> Database -> Connection String -> URI
# 注意：使用 Direct Connection（直连模式），而不是 Pooler
# 示例: postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=

# Flask 会话密钥（不设置会自动生成并持久化到 .secret_key 文件）
# 生产环境建议手动设置并保密
# SECRET_KEY=your_secret_key_here

# 文章同步冷却时间（分钟），默认 30 分钟
# 同一公众号在此时间内不会重复同步，避免频繁请求导致账号被封禁
# 建议值: 30
ARTICLE_CACHE_TTL=30

# 微信登录会话有效天数，默认 30 天
# 建议值: 30
WX_SESSION_DAYS=30
